{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docker: Compose Up",
      "type": "shell",
      "command": "docker-compose up -d",
      "problemMatcher": [],
      "group": "none",
      "detail": "Start PostgreSQL and Python Backend in background"
    },
    {
      "label": "Frontend: NPM Install",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm install",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Vite Dev",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "command": "npm run dev",
      "isBackground": true,
      "problemMatcher": [
        {
          "pattern": [
            {
              "regexp": "^.*$",
              "file": 1,
              "location": 2,
              "message": 3
            }
          ],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "VITE",
            "endsPattern": "ready in"
          }
        }
      ]
    },
    {
      "label": "Backend: Install Requirements",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "command": "${workspaceFolder}/.venv/Scripts/python.exe -m pip install -r requirements.txt",
      "dependsOn": ["Docker: Compose Up"],
      "problemMatcher": []
    }
  ]
}
