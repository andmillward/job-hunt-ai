{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "debugpy",
      "name": "Backend: FastAPI (Local Dev)",
      "request": "launch",
      "program": "${workspaceFolder}/backend/run.py",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "PYTHONPATH": "."
      },
      "preLaunchTask": "Backend: Install Requirements"
    },
    {
      "type": "chrome",
      "name": "Frontend: Debug in Browser",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend",
      "preLaunchTask": "Frontend: Vite Dev"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": [
        "Backend: FastAPI (Local Dev)",
        "Frontend: Debug in Browser"
      ]
    }
  ]
}
